# Whisper model size: tiny, base, small, medium, large
WHISPER_MODEL=base

# CORS allowed origins (comma-separated)
# Include: Admin dev (5173), H5 uni-app dev (5174), H5 production domain
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,https://sayhi.example.com

# Server configuration
HOST=0.0.0.0
PORT=8000

# Debug mode
DEBUG=true
LOG_LEVEL=debug

# Max upload file size in bytes (default: 10MB)
MAX_UPLOAD_SIZE=10485760

# Temporary file directory for audio processing
TEMP_DIR=/tmp/say-hi

# PostgreSQL database URL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sayhi

# JWT configuration
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRE_MINUTES=1440

# WeChat Mini Program
WX_APP_ID=your-wechat-app-id
WX_APP_SECRET=your-wechat-app-secret
